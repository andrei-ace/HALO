# HALO Cloud Service configuration.
# Copy to .env and fill in required values. Source before running:
#   source cloud_service/.env && make run-cloud-service

# Required
export GOOGLE_API_KEY=

# Model overrides
# export HALO_PLANNER_MODEL=gemini-3.1-flash-lite-preview
# export HALO_VLM_MODEL=gemini-3.1-flash-lite-preview

# Context compaction
# export HALO_COMPACTION_INTERVAL=20
# export HALO_COMPACTION_OVERLAP=4

# Firestore persistence (auto-enabled when FIRESTORE_EMULATOR_HOST is set)
# export HALO_FIRESTORE_ENABLED=true
# export HALO_FIRESTORE_COLLECTION=halo_sessions
# export HALO_FIRESTORE_TTL_HOURS=1.0

# Live Agent (WebSocket audio+text streaming)
# export HALO_LIVE_AGENT_ENABLED=true
# export HALO_LIVE_AGENT_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
# export HALO_LIVE_AGENT_VOICE=Kore
