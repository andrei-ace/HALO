# Required for cloud backend
GOOGLE_API_KEY=

# Backend: "cloud" (Gemini) or "local" (Ollama)
HALO_SERVICE_BACKEND=cloud

# Model overrides
# HALO_PLANNER_MODEL=gemini-3.1-flash-lite-preview
# HALO_VLM_MODEL=gemini-3.1-flash-lite-preview

# Optional: Bearer token for endpoint auth (skip if unset)
# HALO_CLOUD_API_KEY=

# Only for backend=local
# HALO_OLLAMA_URL=http://localhost:11434
