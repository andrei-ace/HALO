<mujoco model="pick_scene">
  <include file="so101_new_calib.xml"/>

  <!-- Suppress contact slippage: elliptic cones + high impratio + noslip post-processing -->
  <option impratio="10" cone="elliptic" noslip_iterations="3"/>

  <visual>
    <quality shadowsize="0"/>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="160" elevation="-20" offwidth="1280" offheight="720"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0"
             width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
             rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8"
             width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true"
              texrepeat="5 5" reflectance="0"/>
    <texture type="2d" name="table_tex" builtin="checker"
             rgb1="0.52 0.50 0.46" rgb2="0.46 0.44 0.40"
             width="256" height="256"/>
    <material name="table_material" texture="table_tex" texrepeat="8 8"
              rgba="1 1 1 1"/>
    <material name="green_cube_material" rgba="0.2 0.85 0.3 1"/>
    <material name="red_cube_material" rgba="0.85 0.2 0.2 1"/>
    <material name="tray_material" rgba="0.82 0.71 0.55 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 3.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" pos="0 0 0" type="plane" material="groundplane"/>

    <!-- Table surface: the robot and cube sit on top -->
    <body name="table" pos="0.12 0 0.35">
      <geom type="box" name="table_top" size="0.40 0.35 0.02"
            material="table_material" mass="20"/>
      <!-- Table legs -->
      <geom type="box" size="0.025 0.025 0.165" pos="0.35 0.30 -0.185" rgba="0.36 0.36 0.36 1"/>
      <geom type="box" size="0.025 0.025 0.165" pos="-0.35 0.30 -0.185" rgba="0.36 0.36 0.36 1"/>
      <geom type="box" size="0.025 0.025 0.165" pos="0.35 -0.30 -0.185" rgba="0.36 0.36 0.36 1"/>
      <geom type="box" size="0.025 0.025 0.165" pos="-0.35 -0.30 -0.185" rgba="0.36 0.36 0.36 1"/>
    </body>

    <!-- Overhead scene camera for VLM / observation — opposite robot base, 45° down, avoids arm occlusion -->
    <camera name="scene_cam" pos="0.55 -0.32 0.82" fovy="55" xyaxes="0.41 0.91 0 -0.57 0.26 0.78" mode="fixed"/>

    <!-- Pick target: green cube with freejoint, sits on table top (table top at z=0.37) -->
    <!-- Keep cubes farther apart in Y to reduce tracker cross-target interference. -->
    <body name="green_cube" pos="0.225 -0.08 0.3825">
      <freejoint name="green_cube_joint"/>
      <geom type="box" name="green_cube_geom" size="0.01 0.01 0.0125"
            mass="0.05" material="green_cube_material"
            friction="2.0 0.1 0.001"
            condim="4" priority="1"/>
    </body>

    <!-- Distractor: red cube with freejoint, offset in Y away from green cube -->
    <body name="red_cube" pos="0.225 0.08 0.3825">
      <freejoint name="red_cube_joint"/>
      <geom type="box" name="red_cube_geom" size="0.01 0.01 0.0125"
            mass="0.05" material="red_cube_material"
            friction="2.0 0.1 0.001"
            condim="4" priority="1"/>
    </body>

    <!-- Tray: static container for PLACE_IN_TRAY target (no freejoint → no qpos change) -->
    <!-- Interior ~50mm across (roomy for a 20mm cube), 5mm wall height, 2mm wall thickness -->
    <body name="yellow_tray" pos="0.36 -0.06 0.37">
      <!-- Bottom plate -->
      <geom type="box" name="yellow_tray_bottom" size="0.027 0.027 0.001"
            material="tray_material" mass="0.5"/>
      <!-- Front wall (+X) -->
      <geom type="box" size="0.002 0.027 0.005" pos="0.027 0.0 0.006"
            material="tray_material"/>
      <!-- Back wall (-X) -->
      <geom type="box" size="0.002 0.027 0.005" pos="-0.027 0.0 0.006"
            material="tray_material"/>
      <!-- Left wall (-Y) -->
      <geom type="box" size="0.027 0.002 0.005" pos="0.0 -0.027 0.006"
            material="tray_material"/>
      <!-- Right wall (+Y) -->
      <geom type="box" size="0.027 0.002 0.005" pos="0.0 0.027 0.006"
            material="tray_material"/>
    </body>
  </worldbody>

</mujoco>
